services:
  n8n:
    image: docker.n8n.io/n8nio/n8n:latest
    container_name: n8n
    restart: unless-stopped
    environment:
      - N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
      - N8N_HOST=n8n-kduranet.duckdns.org
      - N8N_PORT=5678
      - N8N_PROTOCOL=https
      - NODE_ENV=production
      - WEBHOOK_URL=https://n8n-kduranet.duckdns.org/
      - GENERIC_TIMEZONE=America/Costa_Rica
      - TZ=America/Costa_Rica
      - N8N_TRUST_PROXY=true
    volumes:
      - n8n_data:/home/node/.n8n
      - ./local-files:/files
    expose:
      - "5678"
    networks:
      - proxy

volumes:
  n8n_data:

networks:
  proxy:
    external: true
