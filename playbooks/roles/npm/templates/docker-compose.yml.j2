services:
  npm:
    image: jc21/nginx-proxy-manager:latest
    container_name: nginx-proxy-manager
    restart: unless-stopped
    ports:
      - "{{ npm_http_port }}:80"
      - "{{ npm_https_port }}:443"
      - "{{ npm_admin_port }}:81"
    environment:
      DISABLE_IPV6: "true"
    volumes:
      - {{ npm_data_dir }}:/data
      - {{ npm_letsencrypt_dir }}:/etc/letsencrypt
    networks:
      - proxy

networks:
  proxy:
    external: true
